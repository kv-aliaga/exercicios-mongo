            caught_at: new Date(1, 4, 2020)
        }
    ]
})

// === CRUD — UPDATE (Update) ===
// Atualize o held_item do Squirtle para "Mystic Water" usando $set.
db.pokemon.updateOne(
    {name: 'Squirtle'},
    {$set: {
        held_item: 'Mystic Water'
    }}
)

// Adicione um novo tipo "Fairy" ao Pokémon que você inseriu (Eevee) usando $push.
db.pokemon.updateOne(
    {name: 'Eevee'},
    {$set: {
        types: ['Normal', 'Fairy']
    }}
)

db.pokemon.updateOne(
    {name: 'Eevee'},
    {$push: {
        types: 'Fairy'
    }}
)

// Remova "Smokescreen" do array moves do Pokémon do Ash que tem dex: 4 (use $pull).
db.trainers.updateOne(
    {
        "team.dex": 4,
        username: "ash"
    },
    {$pull: {
        // varre todo o array
        "team.$.moves": 'Smokescreen'
    }}
)

// Aumente em +5 o level do Pikachu do red (use $inc e filtro correto).
db.trainers.updateOne({
    username: 'red',
    "team.dex": 25
}, {
    $inc: {
        "team.$.level": 5
    }
})

// Use updateMany para marcar todos os treinadores de Kanto com tag: "kanto".
db.trainers.updateMany({
    "region.name": "Kanto"
}, {
    $set: {
        tag: "kanto"
    }
})

// === CRUD — DELETE (Delete) ===
// Apague o treinador brock (deleteOne).
db.trainers.deleteOne({
    username: "brock"
})

// Apague todos os training_rolls com pokemon_dex: 25 (deleteMany).
db.training_rolls.deleteMany({
    pokemon_dex: 25
})

// Apague o Pokémon com dex: 445.
db.pokemon.deleteOne({
    dex: 445
})

// === Projeção e “limpeza” de retorno ===
// Traga apenas username e o tamanho do time (dica: nessa parte dá pra usar agregação, mas tente primeiro só projeção simples; depois você faz a versão avançada na seção 13).
db.trainers.find({}, {
    _id: 0, username: 1, team_size: {$size: "$team"}
})

// Liste Pokémon mostrando apenas: name, base_stats.atk, base_stats.spe
db.pokemon.find({}, {
    _id: 0, name: 1, "base_stats.atk": 1, "base_stats.spe": 1
})

// Liste treinadores escondendo contact por completo (excluir campo).
db.trainers.find({}, {
    contact: 0
})

// === Consultas com $expr (comparações inteligentes) ===
// Treinadores com pelo menos 3 Pokémon no time usando $expr + $size.
db.trainers.find({
    $expr: {
        $gte: [
            {$size: "$team"}, 3
        ]
    }
}, {_id: 0, username: 1, team_size: {$size: "$team"}})

// Treinadores cuja age seja maior que league.gyms_required.
db.trainers.find({
    $expr: {$gt: ["$age", "$league.gyms_required"]}
}, {_id: 0, username: 1, age: 1, "league.gyms_required": 1})

// Pokémon onde base_stats.atk seja maior que base_stats.def.
db.pokemon.find({
    $expr: {$gt: ["$base_stats.atk", "$base_stats.def"]}
}, {_id: 0, name: 1})

// === Desafios finais (mistura tudo) ===
// Encontre treinadores que: sejam is_competing: true, tenham pelo menos 1 Pokémon com level >= 60 e tenham contact.discord existente
db.trainers.find({
    is_competing: true,
    "contact.discord": {$exists: true},
    team: {$elemMatch: {
        level: {$gte: 60}
    }}
}, {
    _id: 0, username: 1, is_competing: 1, contact: 1, "team.level": 1
})

// Encontre Pokémon que: tenham 2 tipos, não sejam lendários, e tenham catch_rate >= 60
db.pokemon.find({
    is_legendary: false,
    catch_rate: {$gte: 60},
    $expr: {
        $eq: [{$size: "$types"}, 2]
    }
}, {_id: 0, name: 1, is_legendary: 1, catch_rate: 1, types: 1}
)

// Crie um campo power em todos os Pokémon calculado como: hp + atk + def + spa + spd + spe
db.pokemon.find({}, {
    _id: 0,
    name: 1,
    power: {
        $add: [
            "$base_stats.hp",
            "$base_stats.atk",
            "$base_stats.def",
            "$base_stats.spa",
            "$base_stats.spd",
            "$base_stats.spe"
        ]
    }
})